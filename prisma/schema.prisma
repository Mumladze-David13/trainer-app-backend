// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TRAINER
  CLIENT
  TRAINER_CLIENT
}

enum WeightType {
  WEIGHT_KG
  BODYWEIGHT
  MACHINE
}

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
  UNLIMITED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      Role
  fcmToken  String?
  gymId     String?
  address   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gym Gym? @relation(fields: [gymId], references: [id], onDelete: SetNull)

  // As trainer: exercises and clients belong to this trainer
  exercises      TrainerExercise[]
  trainerClients TrainerClient[] @relation("TrainerToClient")
  settings       TrainerSettings?

  // As client: belongs to a trainer
  clientOf TrainerClient[] @relation("ClientToTrainer")
  workoutCompletions WorkoutCompletion[]

  trainerConversations Conversation[] @relation("TrainerConversations")
  clientConversations  Conversation[] @relation("ClientConversations")
  sentMessages         Message[]      @relation("SentMessages")
  aiUsageLogs          AiUsageLog[]

  nutritionProfile  NutritionProfile?
  mealPlans         MealPlan[]
  weightLogs        WeightLog[]
  clientSessions    ClientSession[]
  clientActivities  ClientActivity[]
}

model TrainerSettings {
  id                String           @id @default(uuid())
  trainerId         String           @unique
  sessionsPerSeason Int              @default(30)
  plan              SubscriptionPlan @default(FREE)
  trainer           User             @relation(fields: [trainerId], references: [id], onDelete: Cascade)
}

// Which clients belong to which trainer
model TrainerClient {
  id        String   @id @default(uuid())
  trainerId String
  clientId  String
  createdAt DateTime @default(now())

  trainer User @relation("TrainerToClient", fields: [trainerId], references: [id], onDelete: Cascade)
  client  User @relation("ClientToTrainer", fields: [clientId], references: [id], onDelete: Cascade)

  seasons Season[]

  @@unique([trainerId, clientId])
}

// Client settings (chosen trainer)
model ClientSettings {
  id        String @id @default(uuid())
  clientId  String @unique
  trainerId String?
}

model TrainerExercise {
  id               String     @id @default(uuid())
  name             String
  description      String?
  trainerId        String
  weightType       WeightType @default(WEIGHT_KG)
  metValue         Float?
  equipment        String?
  globalExerciseId String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  trainer                User                   @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  globalExercise          GlobalExercise?        @relation(fields: [globalExerciseId], references: [id], onDelete: SetNull)
  workoutExercises       WorkoutExercise[]
  clientSessionExercises ClientSessionExercise[]

  @@unique([name, trainerId])
}

// Глобальный справочник (из free-exercise-db + добавленные администратором)
model GlobalExercise {
  id               String   @id @default(uuid())
  name             String   @unique
  nameRus          String?
  description      String?
  category         String?  // силовые | растяжка | кардио | плиометрика
  equipment        String?  // штанга | гантели | собственный вес | тренажёр
  level            String?  // beginner | intermediate | advanced
  primaryMuscles   String[]
  secondaryMuscles String[]
  imageUrl         String?
  sourceId         String?  // id из free-exercise-db (legacy_xxx для мигрированных)
  createdAt        DateTime @default(now())

  trainerExercises TrainerExercise[]
}

model Season {
  id              String        @id @default(uuid())
  name            String
  startDate       DateTime
  endDate         DateTime?
  trainerClientId String
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())

  trainerClient TrainerClient @relation(fields: [trainerClientId], references: [id], onDelete: Cascade)
  workouts      Workout[]
}

model Workout {
  id          String   @id @default(uuid())
  seasonId    String
  date        DateTime @default(now())
  notes       String?
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  season           Season            @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  workoutExercises WorkoutExercise[]
  completion       WorkoutCompletion?
}

model WorkoutExercise {
  id              String  @id @default(uuid())
  workoutId       String
  exerciseId      String
  sets            Int     @default(1)
  reps            Int     @default(10)
  weight          Float?
  setWeights      String?
  setReps         String?
  durationMinutes Float?
  supersetGroup   Int?
  supersetOrder   Int?
  order           Int     @default(0)
  isDone          Boolean @default(false)

  workout  Workout         @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise TrainerExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

model WorkoutCompletion {
  id        String   @id @default(uuid())
  workoutId String   @unique
  clientId  String
  completedAt DateTime @default(now())

  workout Workout @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  client  User    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String   @id @default(uuid())
  trainerId String
  clientId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trainer   User     @relation("TrainerConversations", fields: [trainerId], references: [id])
  client    User     @relation("ClientConversations", fields: [clientId], references: [id])
  messages  Message[]

  @@unique([trainerId, clientId])
}

model AiUsageLog {
  id           String   @id @default(uuid())
  trainerId    String
  inputTokens  Int
  outputTokens Int
  totalTokens  Int
  costUsd      Float
  operation    String
  createdAt    DateTime @default(now())

  trainer User @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([trainerId, createdAt])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  text           String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
}

model NutritionProfile {
  id                 String    @id @default(uuid())
  clientId           String    @unique
  gender             String
  age                Int
  weightKg           Float
  heightCm           Float
  activityLevel      String
  goal               String
  targetWeeklyChange Float?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  client    User       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  mealPlans MealPlan[]
}

model FoodItem {
  id              String     @id @default(uuid())
  name            String
  caloriesPer100g Float
  proteinPer100g  Float
  carbsPer100g    Float
  fatPer100g      Float
  category        String?
  createdBy       String?
  createdAt       DateTime   @default(now())

  mealItems MealItem[]

  @@unique([name])
}

model MealPlan {
  id                 String   @id @default(uuid())
  nutritionProfileId String
  clientId           String
  date               DateTime @db.Date
  targetCalories     Float?
  targetProtein      Float?
  targetCarbs        Float?
  targetFat          Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  nutritionProfile NutritionProfile @relation(fields: [nutritionProfileId], references: [id], onDelete: Cascade)
  client           User             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  meals            Meal[]

  @@unique([clientId, date])
}

model Meal {
  id         String   @id @default(uuid())
  mealPlanId String
  type       String
  time       String?
  notes      String?
  createdAt  DateTime @default(now())

  mealPlan MealPlan   @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  items    MealItem[]
}

model MealItem {
  id          String @id @default(uuid())
  mealId      String
  foodItemId  String
  amountGrams Float

  meal     Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  foodItem FoodItem @relation(fields: [foodItemId], references: [id])
}

model WeightLog {
  id       String   @id @default(uuid())
  clientId String
  weightKg Float
  date     DateTime @default(now())
  notes    String?

  client User @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, date])
}

model ClientSession {
  id        String   @id @default(uuid())
  clientId  String
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client    User                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  exercises ClientSessionExercise[]
}

model ClientActivity {
  id          String   @id @default(uuid())
  clientId    String
  name        String
  metValue    Float?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client           User                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sessionExercises ClientSessionExercise[]

  @@unique([name, clientId])
}

model ClientSessionExercise {
  id               String  @id @default(uuid())
  sessionId        String
  exerciseId       String?
  clientActivityId String?
  sets             Int?
  reps             Int?
  weight           Float?
  durationMinutes  Float?
  order            Int     @default(0)

  session        ClientSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise       TrainerExercise? @relation(fields: [exerciseId], references: [id])
  clientActivity ClientActivity?  @relation(fields: [clientActivityId], references: [id])
}

model Gym {
  id        String   @id @default(uuid())
  name      String   @unique
  address   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}
